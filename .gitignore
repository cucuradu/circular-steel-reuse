# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual envs / tooling
.venv/
venv/
.ruff_cache/
.pytest_cache/

# Generated artifacts
*.log
out/
/reports/
data/generated/
models/
# Thesis: only the markdown source is tracked; html/pdf are rebuilt by build_thesis_pdf.py
# (the PDF ships attached to the GitHub release).
THESIS*.html
THESIS*.pdf

# SteelReuse Revit add-on: machine-specific interpreter config + per-run match outputs
steelreuse_runner_config.json
steelreuse_reports/

# Secrets (LLM API keys etc.)
.env
*.key

# Scratch
_commitmsg.txt

# Claude Code harness state (agent worktrees, local settings)
.claude/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Maid (local read-only worker): track the harness + routine templates, ignore transient I/O
maid/queue/*
maid/reports/*
maid/done/*
maid/logs/*
!maid/queue/.gitkeep
!maid/reports/.gitkeep
!maid/done/.gitkeep
!maid/logs/.gitkeep
# routine templates are committed (they are the source of truth for recurring tasks)
