<!-- .../lib/steelreuse_set_audit.xaml -->
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelReuse — Set Audit" SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
  <StackPanel Margin="12">
    <TextBlock Text="Write audit data onto the selected framing / columns."
               TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,10"/>
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="150"/><ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock Text="Condition grade (A–D)" Grid.Row="0" Grid.Column="0"
                 VerticalAlignment="Center" Margin="0,4"/>
      <ComboBox x:Name="condition" Grid.Row="0" Grid.Column="1" Margin="0,4"/>

      <TextBlock Text="Verification basis" Grid.Row="1" Grid.Column="0"
                 VerticalAlignment="Center" Margin="0,4"/>
      <ComboBox x:Name="verification" Grid.Row="1" Grid.Column="1" Margin="0,4"/>

      <TextBlock Text="Knockdown (blank = derive)" Grid.Row="2" Grid.Column="0"
                 VerticalAlignment="Center" Margin="0,4"/>
      <TextBox x:Name="knockdown" Grid.Row="2" Grid.Column="1" Margin="0,4"/>

      <TextBlock Text="Recoverable length mm (blank = full)" Grid.Row="3" Grid.Column="0"
                 VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,4"/>
      <TextBox x:Name="recoverable" Grid.Row="3" Grid.Column="1" Margin="0,4"/>

      <TextBlock Text="Defects (free text)" Grid.Row="4" Grid.Column="0"
                 VerticalAlignment="Center" Margin="0,4"/>
      <TextBox x:Name="defects" Grid.Row="4" Grid.Column="1" Margin="0,4"/>
    </Grid>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button x:Name="okBtn" Content="Write to selection" Width="140" Margin="0,0,8,0"/>
      <Button x:Name="cancelBtn" Content="Cancel" Width="80"/>
    </StackPanel>
  </StackPanel>
</Window>
