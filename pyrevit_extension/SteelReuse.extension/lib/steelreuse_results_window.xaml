<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelReuse - Results" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
    </Style>
    <Style TargetType="Label">
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </Window.Resources>

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Run picker -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Label Grid.Column="0" Content="Run"/>
      <ComboBox Grid.Column="1" x:Name="run_combo" Margin="6,0" VerticalAlignment="Center"/>
      <StackPanel Grid.Column="2" Orientation="Horizontal">
        <Button x:Name="refresh_button" Content="Refresh"/>
        <Button x:Name="holder_button" Content="Change holder..."/>
        <Button x:Name="openfile_button" Content="Open file..."/>
      </StackPanel>
    </Grid>

    <!-- KPI header -->
    <TextBlock Grid.Row="1" x:Name="kpi_text" Margin="0,8,0,0" FontSize="14"
               Text="Pick a saved run above to review its matches."/>

    <!-- Display filters (never re-run a match) -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8">
      <Label Content="Status"/>
      <ComboBox x:Name="status_filter" Width="110" VerticalAlignment="Center" SelectedIndex="0">
        <ComboBoxItem Content="all"/>
        <ComboBoxItem Content="filled"/>
        <ComboBoxItem Content="review"/>
        <ComboBoxItem Content="contention"/>
      </ComboBox>
      <Label Content="Section" Margin="12,0,0,0"/>
      <TextBox x:Name="section_filter" Width="130" VerticalAlignment="Center" Padding="3"/>
      <Label Content="Min util" Margin="12,0,0,0"/>
      <TextBox x:Name="minutil_filter" Width="60" VerticalAlignment="Center" Padding="3"/>
    </StackPanel>

    <TabControl Grid.Row="3">
      <TabItem Header="Assignments">
        <DataGrid x:Name="grid" AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  CanUserSortColumns="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Slot" Binding="{Binding slot_id}" Width="90"/>
            <DataGridTextColumn Header="Demand id" Binding="{Binding demand_id}" Width="80"/>
            <DataGridTextColumn Header="Demand sec." Binding="{Binding demand_section}" Width="95"/>
            <DataGridTextColumn Header="Donor id" Binding="{Binding donor_id}" Width="80"/>
            <DataGridTextColumn Header="Donor sec." Binding="{Binding donor_section}" Width="95"/>
            <DataGridTextColumn Header="Util" Binding="{Binding utilization, StringFormat=N2}" Width="55">
              <DataGridTextColumn.ElementStyle>
                <Style TargetType="TextBlock">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding util_severity}" Value="ok">
                      <Setter Property="Foreground" Value="#0A6"/><Setter Property="FontWeight" Value="Bold"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding util_severity}" Value="high">
                      <Setter Property="Foreground" Value="#B8860B"/><Setter Property="FontWeight" Value="Bold"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding util_severity}" Value="over">
                      <Setter Property="Foreground" Value="#C33"/><Setter Property="FontWeight" Value="Bold"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </DataGridTextColumn.ElementStyle>
            </DataGridTextColumn>
            <DataGridTextColumn Header="Status" Binding="{Binding status}" Width="65"/>
            <DataGridTextColumn Header="Gov. case" Binding="{Binding governing}" Width="120"/>
            <DataGridTextColumn Header="CO2 (kg)" Binding="{Binding co2_saved_kg, StringFormat=N0}" Width="75"/>
            <DataGridTextColumn Header="Next best" Binding="{Binding alt_display}" Width="190"/>
          </DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="By section">
        <TextBox x:Name="rollup_text" IsReadOnly="True" FontFamily="Consolas"
                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
      </TabItem>
      <TabItem Header="Donor provenance">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" x:Name="provenance_summary_text" Margin="0,4,0,6"
                     TextWrapping="Wrap" FontSize="12"
                     Text="Run a fresh match to populate the donor-provenance log."/>
          <DataGrid Grid.Row="1" x:Name="mismatch_grid" AutoGenerateColumns="False" IsReadOnly="True"
                    HeadersVisibility="Column" GridLinesVisibility="Horizontal" CanUserSortColumns="True">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Donor id" Binding="{Binding donor_id}" Width="90"/>
              <DataGridTextColumn Header="Raw name" Binding="{Binding raw_section}" Width="160"/>
              <DataGridTextColumn Header="Section" Binding="{Binding section}" Width="90"/>
              <DataGridTextColumn Header="Class" Binding="{Binding classification}" Width="95"/>
              <DataGridTextColumn Header="Outcome" Binding="{Binding outcome}" Width="70"/>
              <DataGridTextColumn Header="Reason" Binding="{Binding reason}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>
    </TabControl>

    <!-- Footer: drill-down + report actions -->
    <DockPanel Grid.Row="4" Margin="0,10,0,0">
      <Button x:Name="zoom_button" Content="Zoom to selected" DockPanel.Dock="Left"
              Background="#0A6EBD" Foreground="White" FontWeight="Bold"/>
      <Button x:Name="trace_button" Content="Trace to partner model" DockPanel.Dock="Left"/>
      <Button x:Name="apply_button" Content="Apply this run to model" DockPanel.Dock="Left"
              Margin="16,0,0,0"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="open_report_button" Content="Open report"/>
        <Button x:Name="open_evidence_button" Content="Open evidence"/>
        <Button x:Name="open_folder_button" Content="Open folder"/>
        <Button x:Name="export_button" Content="Export CSV"/>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
