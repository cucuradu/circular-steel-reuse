<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelReuse - Compare runs" Height="620" Width="860"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="170"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Margin="0,0,0,6"
               Text="Saved runs - select two or more (Ctrl/Shift-click), then Compare."/>

    <ListBox Grid.Row="1" x:Name="runs_list" SelectionMode="Extended" FontFamily="Consolas"
             HorizontalContentAlignment="Stretch"/>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8">
      <Button x:Name="compare_button" Content="Compare selected" Background="#00A651"
              Foreground="White" FontWeight="Bold" Padding="14,5"/>
      <Button x:Name="delete_button" Content="Delete selected" Padding="14,5" Margin="8,0,0,0"/>
      <Button x:Name="refresh_button" Content="Refresh" Padding="14,5" Margin="8,0,0,0"/>
    </StackPanel>

    <TextBox Grid.Row="3" x:Name="compare_output" IsReadOnly="True" FontFamily="Consolas"
             TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"/>
  </Grid>
</Window>
