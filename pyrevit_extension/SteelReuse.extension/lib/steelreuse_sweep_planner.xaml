<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SteelReuse - Scenario sweep" Height="700" Width="760"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
    </Style>
    <Style TargetType="Label">
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="3,2"/>
    </Style>
  </Window.Resources>

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#444"
               Text="Lock the donor + demand, pick which dials to vary, and run every combination at once. Each combination is a normal, lean match run; the trade-off board then shows which settings reuse the most and what each choice costs in the others."/>

    <!-- Donor / demand -->
    <Grid Grid.Row="1" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="110"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Label Grid.Row="0" Grid.Column="0" Content="Donor model"/>
      <TextBox Grid.Row="0" Grid.Column="1" x:Name="donor_box" Margin="0,2"/>
      <Button Grid.Row="0" Grid.Column="2" x:Name="donor_browse" Content="Browse..."/>
      <Label Grid.Row="1" Grid.Column="0" Content="Demand model(s)"/>
      <TextBox Grid.Row="1" Grid.Column="1" x:Name="demand_box" Margin="0,2"
               ToolTip="One model, or several separated by ';' (portfolio)."/>
      <Button Grid.Row="1" Grid.Column="2" x:Name="demand_browse" Content="Browse..."/>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,2">
      <Label Content="Dials to vary" FontWeight="Bold"/>
      <TextBlock Text="(tick the values to try for each dial; a dial varies only if you tick at least one)"
                 VerticalAlignment="Center" Foreground="#666" FontSize="11" Margin="6,0,0,0"/>
    </StackPanel>

    <!-- Axes: tick the values to sweep for each dial (no free text -> no misspelling). A dial is
         active iff at least one of its values is ticked; the run count is the product of the ticked
         counts across active dials. -->
    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="160"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Label Grid.Row="0" Grid.Column="0" Content="Optimise for"/>
      <WrapPanel Grid.Row="0" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="obj_co2" Content="co2" IsChecked="True" Margin="0,0,14,0"/>
        <CheckBox x:Name="obj_members" Content="members" IsChecked="True" Margin="0,0,14,0"/>
        <CheckBox x:Name="obj_mass" Content="mass" IsChecked="True" Margin="0,0,14,0"/>
        <CheckBox x:Name="obj_balanced" Content="balanced" Margin="0,0,14,0"/>
      </WrapPanel>

      <Label Grid.Row="1" Grid.Column="0" Content="Min utilisation"/>
      <WrapPanel Grid.Row="1" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="mu_00" Content="0.0" Margin="0,0,14,0"/>
        <CheckBox x:Name="mu_05" Content="0.5" Margin="0,0,14,0"/>
        <CheckBox x:Name="mu_06" Content="0.6" Margin="0,0,14,0"/>
        <CheckBox x:Name="mu_07" Content="0.7" Margin="0,0,14,0"/>
      </WrapPanel>

      <Label Grid.Row="2" Grid.Column="0" Content="Max distinct sections"/>
      <WrapPanel Grid.Row="2" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="ms_none" Content="none" Margin="0,0,14,0"/>
        <CheckBox x:Name="ms_6" Content="6" Margin="0,0,14,0"/>
        <CheckBox x:Name="ms_8" Content="8" Margin="0,0,14,0"/>
        <CheckBox x:Name="ms_10" Content="10" Margin="0,0,14,0"/>
      </WrapPanel>

      <Label Grid.Row="3" Grid.Column="0" Content="Knockdown"/>
      <WrapPanel Grid.Row="3" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="kd_10" Content="1.0" Margin="0,0,14,0"/>
        <CheckBox x:Name="kd_09" Content="0.9" Margin="0,0,14,0"/>
        <CheckBox x:Name="kd_085" Content="0.85" Margin="0,0,14,0"/>
        <CheckBox x:Name="kd_08" Content="0.8" Margin="0,0,14,0"/>
      </WrapPanel>

      <Label Grid.Row="4" Grid.Column="0" Content="Carbon dataset"/>
      <WrapPanel Grid.Row="4" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="cb_ice_v3" Content="ice_v3" Margin="0,0,14,0"/>
        <CheckBox x:Name="cb_ice_v4" Content="ice_v4" Margin="0,0,14,0"/>
        <CheckBox x:Name="cb_oekobaudat" Content="oekobaudat" Margin="0,0,14,0"/>
      </WrapPanel>

      <Label Grid.Row="5" Grid.Column="0" Content="Carbon credit basis"/>
      <WrapPanel Grid.Row="5" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="cf_none" Content="none" Margin="0,0,14,0"/>
        <CheckBox x:Name="cf_recycling" Content="recycling" Margin="0,0,14,0"/>
        <CheckBox x:Name="cf_rerolling" Content="rerolling" Margin="0,0,14,0"/>
      </WrapPanel>

      <Label Grid.Row="6" Grid.Column="0" Content="Prefer lightest donor"/>
      <WrapPanel Grid.Row="6" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="wo_0" Content="off (0.0)" Margin="0,0,14,0"/>
        <CheckBox x:Name="wo_03" Content="on (0.3)" Margin="0,0,14,0"/>
      </WrapPanel>

      <Label Grid.Row="7" Grid.Column="0" Content="Splicing"/>
      <WrapPanel Grid.Row="7" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="sp_off" Content="off" Margin="0,0,14,0"/>
        <CheckBox x:Name="sp_on" Content="on" Margin="0,0,14,0"/>
      </WrapPanel>

      <Label Grid.Row="8" Grid.Column="0" Content="National Annex"/>
      <WrapPanel Grid.Row="8" Grid.Column="1" Margin="0,3">
        <CheckBox x:Name="na_en" Content="en" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_dk" Content="dk" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_fi" Content="fi" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_cy" Content="cy" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_es" Content="es" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_be" Content="be" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_it" Content="it" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_uk" Content="uk" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_de" Content="de" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_fr" Content="fr" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_nl" Content="nl" Margin="0,0,12,0"/>
        <CheckBox x:Name="na_ie" Content="ie" Margin="0,0,12,0"/>
      </WrapPanel>
    </Grid>

    <!-- Workers + grid count -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
      <Label Content="Parallel runs"/>
      <TextBox x:Name="workers_box" Width="50" Margin="4,0,0,0"
               ToolTip="Engine processes to run at once (default = CPU count - 1)."/>
      <Label x:Name="count_text" Content="1 run(s)" Margin="20,0,0,0" FontWeight="Bold"/>
    </StackPanel>

    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,10">
      <Button x:Name="run_button" Content="Run sweep" Background="#00A651" Foreground="White"
              FontWeight="Bold" Padding="16,5"/>
    </StackPanel>

    <TextBox Grid.Row="6" x:Name="progress_box" IsReadOnly="True" TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto" Background="#FFFFFF" BorderBrush="#DDD"
             FontFamily="Consolas" Text=""/>
  </Grid>
</Window>
